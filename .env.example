# Base de données (Postgres + pgvector via docker-compose)
DATABASE_URL=postgresql+psycopg://xmed:xmed@localhost:5432/xmed

# Corpus PubMed local (téléchargé par data/pubmed/download_corpus.sh)
DATA_DIR=/home/geekette/data/pubmed

# Modèles d'embedding actifs (clés du registre — voir app/services/embeddings.py)
EMBEDDING_MODELS=medcpt,bge_m3

# API
API_HOST=0.0.0.0
API_PORT=8000
# Origines autorisées pour le frontend (CORS)
CORS_ORIGINS=http://localhost:3000

# Optionnel : seulement si on compare text-embedding-3-large (OpenAI) plus tard
# OPENAI_API_KEY=sk-...
